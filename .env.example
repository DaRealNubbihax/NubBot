# ============================================================
# PolyCode AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# For Vercel, add these in Project Settings → Environment Variables.

# --- SUPABASE (required) ---
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# API KEYS — Add these as Supabase Edge Function Secrets
# ============================================================
# These are NOT frontend variables. They go in:
#   Supabase Dashboard → Edge Functions → Secrets
#
# ANTHROPIC_API_KEY   → https://console.anthropic.com/settings/keys
#                        Powers: Claude Sonnet, Claude Opus
#
# OPENAI_API_KEY      → https://platform.openai.com/api-keys
#                        Powers: GPT-4o, GPT-4 Turbo
#
# GOOGLE_AI_API_KEY   → https://aistudio.google.com/app/apikey
#                        Powers: Gemini 1.5 Pro
#
# MISTRAL_API_KEY     → https://console.mistral.ai/api-keys
#                        Powers: Mistral Large
# ============================================================
